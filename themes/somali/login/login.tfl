<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <title>${msg("loginTitle", (realm.displayName!''))}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>

    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
        rel="stylesheet"
    />

    <link rel="stylesheet" href="${url.resourcesPath}/css/login.css" />
</head>

<body>

    <!-- Background -->
    <div class="bg-scene"></div>

    <div class="bg-dash" aria-hidden="true">
        <div class="dash-card"><div class="label"></div><div class="value"></div></div>
        <div class="dash-card"><div class="label"></div><div class="value"></div></div>
        <div class="dash-card"><div class="label"></div><div class="value"></div></div>
        <div class="dash-card"><div class="label"></div><div class="value"></div></div>

        <div class="dash-chart"></div>
        <div class="dash-chart"></div>
        <div class="dash-donut"></div>
        <div class="dash-map"></div>
    </div>

    <!-- Login Card -->
    <div class="card-wrap">

        <div class="card">

            <!-- Brand -->
            <div class="brand">
                <div class="brand-icon">j</div>
                <span class="brand-name">
                    ${realm.displayName!'jsreports'}
                </span>
            </div>

            <!-- Heading -->
            <h1 class="card-title">
                ${msg("loginAccountTitle")}
            </h1>

            <p class="card-subtitle">
                Securely continue to your dashboard
            </p>

            <!-- Error Messages -->
            <#if message?has_content && (message.type == 'error' || message.type == 'warning')>
                <div class="alert" role="alert">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>

                    <span>
                        ${kcSanitize(message.summary)?no_esc}
                    </span>
                </div>
            </#if>

            <!-- Form -->
            <form id="kc-form-login"
                  action="${url.loginAction}"
                  method="post">

                <!-- Username -->
                <div class="field">

                    <label class="field-label" for="username">
                        ${msg("usernameOrEmail")}
                    </label>

                    <div class="input-wrap">

                        <span class="input-icon">
                            <svg width="16" height="16" fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="2">

                                <path d="M4 4h16c1.1 0 2 .9 2 2v12
                                         c0 1.1-.9 2-2 2H4
                                         c-1.1 0-2-.9-2-2V6
                                         c0-1.1.9-2 2-2z"/>

                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>

                        <input
                            id="username"
                            name="username"
                            type="text"
                            autocomplete="username"
                            value="${(login.username!'')?html}"
                            placeholder="${msg('usernameOrEmail')}"
                            autofocus
                        />
                    </div>
                </div>

                <!-- Password -->
                <div class="field">

                    <label class="field-label" for="password">
                        ${msg("password")}
                    </label>

                    <div class="input-wrap">

                        <span class="input-icon">
                            <svg width="16" height="16"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="2">

                                <rect x="3" y="11"
                                      width="18"
                                      height="11"
                                      rx="2"
                                      ry="2"/>

                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>

                        <input
                            id="password"
                            name="password"
                            type="password"
                            autocomplete="current-password"
                            placeholder="••••••••"
                        />

                        <button
                            type="button"
                            class="pwd-toggle"
                            onclick="togglePassword(this)"
                            aria-label="${msg('showPassword')}"
                        >
                            👁
                        </button>

                    </div>
                </div>

                <!-- Remember / Forgot -->
                <div class="form-extras">

                    <#if realm.rememberMe>
                        <label class="remember-wrap">

                            <input
                                type="checkbox"
                                name="rememberMe"

                                <#if login.rememberMe??>
                                    checked
                                </#if>
                            />

                            <span>
                                ${msg("rememberMe")}
                            </span>

                        </label>
                    </#if>

                    <#if realm.resetPasswordAllowed>
                        <a class="forgot-link"
                           href="${url.loginResetCredentialsUrl}">

                            ${msg("doForgotPassword")}

                        </a>
                    </#if>

                </div>

                <!-- Hidden -->
                <input
                    type="hidden"
                    id="id-hidden-input"
                    name="credentialId"

                    <#if auth.selectedCredential?has_content>
                        value="${auth.selectedCredential}"
                    </#if>
                />

                <!-- Submit -->
                <button
                    class="btn-login"
                    type="submit"
                    name="login"
                >
                    ${msg("doLogIn")}
                </button>

            </form>

            <!-- Register -->
            <#if realm.registrationAllowed && !registrationDisabled??>

                <p class="signup-row">

                    ${msg("noAccount")}

                    <a href="${url.registrationUrl}">
                        ${msg("doRegister")}
                    </a>

                </p>

            </#if>

        </div>
    </div>

    <script>
        function togglePassword(button) {

            const input =
                button.closest('.input-wrap')
                .querySelector('input');

            if (input.type === 'password') {
                input.type = 'text';
                button.innerHTML = '🙈';
            } else {
                input.type = 'password';
                button.innerHTML = '👁';
            }
        }
    </script>

</body>
</html>